---
import { withBase } from "../lib/paths";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  home?: boolean;
}

const {
  title = "郭小儒的博客",
  description = "郭小儒的个人博客，记录技术文章、项目实践、生活观察和长期积累。",
  home = false,
} = Astro.props;

const siteName = "郭小儒的博客";
const pageTitle = title === siteName ? title : `${title} | ${siteName}`;
const currentPath = Astro.url.pathname.endsWith("/") && Astro.url.pathname !== "/"
  ? Astro.url.pathname.slice(0, -1)
  : Astro.url.pathname;
const navItems = [
  { href: "/about", label: "About" },
  { href: "/projects", label: "Projects" },
  { href: "/posts", label: "Blog" },
  { href: "/life", label: "Life" },
  { href: "/contact", label: "Contact" },
];
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <link rel="icon" href={withBase("/favicon.svg")} type="image/svg+xml" />
  </head>
  <body class:list={[home && "is-home"]}>
    <header class="site-header">
      <a class="brand" href={withBase("/")} aria-label="回到首页">
        <span class="brand-mark" aria-hidden="true">儒</span>
        <span>{siteName}</span>
      </a>
      <nav class="site-nav" aria-label="主导航">
        {
          navItems.map((item) => (
            <a href={withBase(item.href)} class={currentPath === withBase(item.href).replace(/\/$/, "") ? "active" : ""}>
              {item.label}
            </a>
          ))
        }
      </nav>
    </header>
    <main class:list={[home ? "home-main" : "page-main"]}>
      <slot />
    </main>
  </body>
</html>
