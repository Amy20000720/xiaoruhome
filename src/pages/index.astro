---
import BaseLayout from "../layouts/BaseLayout.astro";
import { withBase } from "../lib/paths";

const townPlaces = [
  {
    className: "place-about",
    href: "/about",
    title: "About",
    note: "关于我",
    aria: "进入关于我页面",
  },
  {
    className: "place-projects",
    href: "/projects",
    title: "Projects",
    note: "项目",
    aria: "进入项目入口页面",
  },
  {
    className: "place-posts",
    href: "/posts",
    title: "Blog",
    note: "博客",
    aria: "进入博客页面",
  },
  {
    className: "place-life",
    href: "/life",
    title: "Life",
    note: "生活",
    aria: "进入个人生活页面",
  },
  {
    className: "place-contact",
    href: "/contact",
    title: "Contact",
    note: "联系",
    aria: "进入联系我页面",
  },
];
---

<BaseLayout home title="郭小儒" description="郭小儒的个人博客入口，记录技术文章、项目实践、生活观察和联系方式。">
  <section class="home-profile" aria-labelledby="home-title">
    <h1 id="home-title">郭小儒</h1>
    <div class="intro-flow">
      <img
        class="intro-photo"
        src={withBase("/assets/profile/guo-xiaoru-profile.webp")}
        alt="郭小儒的个人照片"
        width="980"
        height="735"
        loading="eager"
        decoding="async"
      />
      <p>
        这里是郭小儒的个人博客。我会把正在学习、正在实践和想长期保存的内容放在这里，包括技术文章、项目记录、生活观察和一些阶段性的想法。
      </p>
      <p>
        我关注 AI 工具、工程效率、内容表达和个人知识管理，也在尝试把复杂问题整理成清晰、可复用、能持续更新的记录。
      </p>
      <p>
        这个网站会慢慢从一个入口页变成一个长期档案：有项目，有文章，也有生活里的照片、读书和旅行片段。
      </p>
      <p class="intro-callout">
        <strong>向下探索我的博客、项目、生活记录和联系方式。</strong>
      </p>
    </div>
  </section>

  <section class="city-explore" aria-labelledby="explore-title">
    <div class="section-heading">
      <p class="eyebrow">Explore</p>
      <h2 id="explore-title">探索我的内容</h2>
    </div>

    <div class="candy-map-shell" aria-label="手绘互动地图导航">
      <div class="candy-map">
        <img
          class="candy-map-image"
          src={withBase("/assets/candy-town/candy-town-map.webp")}
          alt="手绘互动地图，用来进入关于我、项目、博客、生活和联系页面"
          width="1672"
          height="941"
          loading="eager"
          decoding="async"
        />
        {
          townPlaces.map((place) => (
            <a class:list={["map-hotspot", place.className]} href={withBase(place.href)} aria-label={place.aria}>
              <span class="hotspot-pulse" aria-hidden="true"></span>
              <span class="hotspot-label">
                <strong>{place.title}</strong>
                <small>{place.note}</small>
              </span>
            </a>
          ))
        }
      </div>
    </div>

    <nav class="fallback-nav" aria-label="文字导航入口">
      {
        townPlaces.map((place) => (
          <a href={withBase(place.href)}>
            <span>{place.title}</span>
            <small>{place.note}</small>
          </a>
        ))
      }
    </nav>
  </section>
</BaseLayout>
