---
import BaseLayout from "../layouts/BaseLayout.astro";
import { withBase } from "../lib/paths";

const townPlaces = [
  {
    className: "place-about",
    href: "/about",
    title: "关于我",
    note: "糖果小屋",
    aria: "进入关于我页面",
  },
  {
    className: "place-posts",
    href: "/posts",
    title: "技术文章",
    note: "奶油图书馆",
    aria: "进入技术文章页面",
  },
  {
    className: "place-projects",
    href: "/projects",
    title: "项目入口",
    note: "魔法工坊",
    aria: "进入项目入口页面",
  },
  {
    className: "place-life",
    href: "/life",
    title: "个人生活",
    note: "甜品咖啡馆",
    aria: "进入个人生活页面",
  },
  {
    className: "place-contact",
    href: "/contact",
    title: "联系我",
    note: "星星邮局",
    aria: "进入联系我页面",
  },
];
---

<BaseLayout home title="小茹的糖果小镇" description="小茹的中文个人网站入口，展示个人介绍、技术文章、项目、生活记录和联系方式。">
  <section class="candy-home" aria-labelledby="home-title">
    <div class="candy-copy">
      <p class="eyebrow">Dreamy Candy Town</p>
      <h1 id="home-title">欢迎来到小茹的糖果小镇。</h1>
      <p class="lead">
        这里收纳我的个人介绍、技术文章、项目实验、生活记录和联系方式。点击地图里的小镇地点，进入不同的房间。
      </p>
    </div>

    <div class="candy-map-shell" aria-label="梦幻糖果小镇导航地图">
      <div class="candy-map">
        <img
          class="candy-map-image"
          src={withBase("/assets/candy-town/candy-town-map.webp")}
          alt="梦幻糖果小镇手绘地图，包含糖果小屋、奶油图书馆、魔法工坊、甜品咖啡馆和星星邮局"
          width="1672"
          height="941"
          loading="eager"
          decoding="async"
        />
        {
          townPlaces.map((place) => (
            <a class:list={["map-hotspot", place.className]} href={withBase(place.href)} aria-label={place.aria}>
              <span class="hotspot-pulse" aria-hidden="true"></span>
              <span class="hotspot-label">
                <strong>{place.title}</strong>
                <small>{place.note}</small>
              </span>
            </a>
          ))
        }
      </div>
    </div>

    <nav class="fallback-nav" aria-label="糖果小镇文字入口">
      {
        townPlaces.map((place) => (
          <a href={withBase(place.href)}>
            <span>{place.title}</span>
            <small>{place.note}</small>
          </a>
        ))
      }
    </nav>
  </section>
</BaseLayout>
