---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { withBase } from "../../lib/paths";

const projects = (await getCollection("projects", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
---

<BaseLayout title="项目入口" description="小茹的项目、作品和实验入口。">
  <section class="page-hero">
    <p class="eyebrow">Projects</p>
    <h1>项目入口</h1>
    <p class="lead">把正在做、做过、想继续打磨的项目放在这里，方便快速回看和分享。</p>
  </section>

  <section class="section-grid" aria-label="项目列表">
    {
      projects.map((project) => (
        <a class="content-card" href={withBase(`/projects/${project.id}/`)}>
          <div class="meta">
            <time datetime={project.data.date.toISOString()}>{project.data.date.toLocaleDateString("zh-CN")}</time>
            <span>{project.data.status}</span>
          </div>
          <h2>{project.data.title}</h2>
          <p>{project.data.summary}</p>
          <div class="tag-list">
            {project.data.tags.map((tag) => (
              <span class="tag">{tag}</span>
            ))}
          </div>
        </a>
      ))
    }
  </section>
</BaseLayout>
