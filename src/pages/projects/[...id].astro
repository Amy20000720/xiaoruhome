---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const projects = await getCollection("projects", ({ data }) => !data.draft);
  return projects.map((project) => ({
    params: { id: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
---

<BaseLayout title={project.data.title} description={project.data.summary}>
  <article class="entry-page">
    <section class="page-hero">
      <p class="eyebrow">项目</p>
      <h1>{project.data.title}</h1>
      <div class="meta">
        <time datetime={project.data.date.toISOString()}>{project.data.date.toLocaleDateString("zh-CN")}</time>
        <span>{project.data.status}</span>
      </div>
      <div class="tag-list">
        {project.data.tags.map((tag) => <span class="tag">{tag}</span>)}
      </div>
      <div class="button-row">
        {project.data.repo && <a class="text-button" href={project.data.repo}>查看仓库</a>}
        {project.data.demo && <a class="text-button secondary" href={project.data.demo}>查看演示</a>}
      </div>
    </section>
    <div class="entry-content">
      <Content />
    </div>
  </article>
</BaseLayout>
