---
import { readFile, readdir } from "node:fs/promises";
import { join } from "node:path";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { withBase } from "../../lib/paths";
import "../../styles/reading-journal-studio-design.css";

const brownTag = withBase("/assets/life-journal/illustcenter/brown-tag.png");
const whiteTag = withBase("/assets/life-journal/illustcenter/white-tag.png");

type MaterialItem = {
  id: string;
  name: string;
  file: string;
  tags: string[];
};

type MaterialSheetManifest = {
  id: string;
  name: string;
  category: string;
  style: string[];
  source: { provider: string };
  items: MaterialItem[];
};

const sheetsDirectory = join(process.cwd(), "public", "assets", "life-journal", "sheets");
const sheetDirectories = (await readdir(sheetsDirectory, { withFileTypes: true }))
  .filter((entry) => entry.isDirectory())
  .map((entry) => entry.name);

const materialSheets = (
  await Promise.all(
    sheetDirectories.map(async (directory) => {
      const manifestPath = join(sheetsDirectory, directory, "sheet.json");
      const manifest = JSON.parse(await readFile(manifestPath, "utf8")) as MaterialSheetManifest;

      return {
        ...manifest,
        items: manifest.items.map((item) => ({
          ...item,
          src: withBase(`/assets/life-journal/sheets/${directory}/${item.file}`)
        }))
      };
    })
  )
).sort((left, right) => left.id.localeCompare(right.id));

const initialMaterialSheet = materialSheets[0];
const initialMaterialItem = initialMaterialSheet?.items[0];

if (!initialMaterialItem) {
  throw new Error("Reading Journal Studio requires at least one material sheet with an item.");
}
---

<BaseLayout
  title="读书手帐 Studio 视觉稿"
  description="日系干净文学感的单页 B5 读书手帐 Studio 高保真静态设计稿。"
  wide
>
  <section class="journal-design-board" aria-label="读书手帐 Studio 视觉稿">
    <header class="journal-design-hero">
      <div class="hero-copy">
        <p class="eyebrow">Reading Journal Studio / Visual Draft</p>
        <h1>单张 B5 读书手帐工作台</h1>
        <p>
          这版只确认视觉和交互结构：浅色书桌选纸、竖向 B5 自由画布、左侧轮播素材工具箱、右侧相册与 Canva 式文字面板。
        </p>
      </div>
      <div class="hero-spec-card" aria-label="设计约束">
        <span>审美</span>
        <strong>日系干净文学感</strong>
        <small>自由空白页 / 真实素材来源 / 可持续添加</small>
      </div>
    </header>

    <section class="design-screen paper-selection-screen" aria-labelledby="paper-selection-title">
      <div class="screen-heading">
        <p class="screen-index">Screen 01</p>
        <h2 id="paper-selection-title">首页：在书桌上选择 B5 底纸</h2>
        <p>
          首页不进入复杂编辑，只做一件事：左右翻看纸张气质，选择后进入 Studio。
        </p>
      </div>

      <div class="desk-scene" aria-label="书桌选纸设计稿">
        <div class="desk-prop book-stack" aria-hidden="true">
          <span></span>
          <span></span>
          <strong>READING<br />NOTES</strong>
        </div>
        <div class="desk-prop coffee-cup" aria-hidden="true">
          <span></span>
        </div>
        <img class="desk-tag brown-tag" src={brownTag} alt="" loading="lazy" />
        <img class="desk-tag white-tag" src={whiteTag} alt="" loading="lazy" />
        <div class="desk-pen" aria-hidden="true"></div>

        <button class="paper-arrow paper-arrow-left" type="button" aria-label="往前翻页">‹</button>
        <article class="paper-picker-card" aria-label="当前底纸预览">
          <div class="paper-label">
            <span>Paper 02</span>
            <strong>浅灰网格 B5</strong>
          </div>
          <div class="b5-paper-preview paper-grid">
            <div class="preview-date">07 / READING</div>
            <div class="preview-title">空白读书手帐页</div>
            <div class="preview-note">选择底纸后进入工作台，自由添加文字、照片、便签、胶带和贴纸。</div>
          </div>
          <div class="paper-dots" aria-label="底纸页码">
            <span></span>
            <span class="active"></span>
            <span></span>
            <span></span>
            <span></span>
            <span></span>
          </div>
          <button class="primary-paper-button" type="button">选择这张纸</button>
        </article>
        <button class="paper-arrow paper-arrow-right" type="button" aria-label="往后翻页">›</button>

        <aside class="paper-swatches" aria-label="首批底纸">
          <span class="swatch warm"></span>
          <span class="swatch grid active"></span>
          <span class="swatch dot"></span>
          <span class="swatch line"></span>
          <span class="swatch kraft"></span>
          <span class="swatch vellum"></span>
        </aside>
      </div>
    </section>

    <section class="design-screen editor-screen" aria-labelledby="editor-title">
      <div class="screen-heading">
        <p class="screen-index">Screen 02</p>
        <h2 id="editor-title">编辑器：单张 B5 自由拼贴页</h2>
        <p>
          左侧选择素材，中间自由排版，右侧调相册、文字和图层。画布内不预设固定字段。
        </p>
      </div>

      <div class="studio-design-shell" aria-label="读书手帐 Studio 编辑器设计稿">
        <header class="studio-design-toolbar" aria-label="顶部操作栏">
          <button type="button" class="active">选择</button>
          <button type="button">文字</button>
          <button type="button">上传</button>
          <button type="button">撤销</button>
          <button type="button">重做</button>
          <button type="button">上层</button>
          <button type="button">下层</button>
          <button type="button">复制</button>
          <button type="button" class="danger">删除</button>
          <span class="zoom-chip">82%</span>
        </header>

        <div class="studio-design-grid">
          <aside class="material-toolbox" aria-label="轮播素材工具箱">
            <div class="panel-title">
              <strong>素材工具箱</strong>
              <span>Sheet Library</span>
            </div>

            <section class="tool-carousel material-sheet-explorer" data-sheet-explorer aria-labelledby="material-sheet-title">
              <div class="carousel-head">
                <h3 id="material-sheet-title">实物贴纸 Sheets</h3>
                <div class="carousel-arrows" aria-label="翻页浏览素材">
                  <button type="button" data-material-page="previous" aria-label="上一页素材" title="上一页素材">‹</button>
                  <button type="button" data-material-page="next" aria-label="下一页素材" title="下一页素材">›</button>
                </div>
              </div>

              <div class="material-sheet-tabs" role="tablist" aria-label="素材 sheet 选择">
                {
                  materialSheets.map((sheet, index) => (
                    <button
                      type="button"
                      class:list={{ "material-sheet-tab": true, active: index === 0 }}
                      data-material-sheet={index}
                      role="tab"
                      aria-selected={index === 0 ? "true" : "false"}
                    >
                      {sheet.name}
                    </button>
                  ))
                }
              </div>

              <button class="featured-material sheet-featured-material" type="button" data-featured-material aria-label={`当前选择：${initialMaterialItem.name}`}>
                <img src={initialMaterialItem.src} alt={initialMaterialItem.name} data-featured-image loading="lazy" />
              </button>

              <div class="material-thumbnail-grid" data-material-grid>
                {
                  initialMaterialSheet.items.slice(0, 4).map((item, index) => (
                    <button
                      type="button"
                      class:list={{ "material-thumbnail": true, active: index === 0 }}
                      data-material-index={index}
                      aria-pressed={index === 0 ? "true" : "false"}
                      aria-label={`选择${item.name}`}
                    >
                      <img src={item.src} alt="" loading="lazy" />
                    </button>
                  ))
                }
              </div>

              <div class="material-caption">
                <strong data-sheet-name>{initialMaterialSheet.name}</strong>
                <span data-material-name>{initialMaterialItem.name}</span>
                <span data-material-page-counter>1 / {Math.ceil(initialMaterialSheet.items.length / 4)}</span>
              </div>
            </section>
          </aside>

          <main class="b5-workspace" aria-label="单张 B5 画布区域">
            <div class="workspace-meta">
              <span>纸张：浅灰网格 B5</span>
              <span>自由画布</span>
            </div>
            <article class="b5-editor-page" aria-label="B5 手帐页面示例">
              <div class="page-mini-date">04 / JOURNAL</div>
              <div class="page-side-tab">BOOK NOTE</div>
              <div class="book-cover-card">
                <span>BOOK</span>
                <strong>一间<br />自己的房间</strong>
              </div>
              <div class="title-type-block">
                <span>Title / 书名</span>
                <strong>一间，只属于自己的房间</strong>
              </div>
              <div class="quote-card quote-card-main">
                “一个女人如果要写小说，那她必须有钱和一间自己的房间。”
              </div>
              <div class="free-text-block">
                <strong>今天的读书感想</strong>
                <p>页面是空白的，可以像拼贴一样把图片、摘抄、批注和小标签自由组合。</p>
              </div>
              <div class="image-placeholder">
                <span>相册图片</span>
              </div>
              <span class="canvas-tape tape-one"></span>
              <span class="canvas-tape tape-two"></span>
              <span class="canvas-tape tape-three"></span>
              <img class="page-sheet-sticker" src={initialMaterialItem.src} alt={initialMaterialItem.name} data-canvas-material loading="lazy" />
              <div class="selected-box selected-material-box" aria-hidden="true">
                <span></span><span></span><span></span><span></span>
              </div>
            </article>
            <div class="workspace-actions">
              <button type="button">保存草稿</button>
              <button type="button" class="publish">发布</button>
            </div>
          </main>

          <aside class="right-inspector" aria-label="相册、文字和属性面板">
            <section class="inspector-card album-card" aria-labelledby="album-title">
              <div class="panel-title compact">
                <strong id="album-title">我的相册</strong>
                <span>Local Album</span>
              </div>
              <div class="album-grid">
                <button type="button" class="album-upload">上传</button>
                <button type="button" class="album-thumb paper-photo">书封</button>
                <button type="button" class="album-thumb coffee-photo">咖啡</button>
                <button type="button" class="album-thumb note-photo">截图</button>
              </div>
            </section>

            <section class="inspector-card text-card" aria-labelledby="text-title">
              <div class="panel-title compact">
                <strong id="text-title">文字设置</strong>
                <span>Canva Style</span>
              </div>
              <div class="text-presets" aria-label="文字预设">
                <button type="button" class="preset-serif">书名标题</button>
                <button type="button" class="preset-wenkai active">正文摘抄</button>
                <button type="button" class="preset-hand">手写金句</button>
                <button type="button" class="preset-label">标签小字</button>
              </div>
              <label>
                字体
                <select>
                  <option>霞鹜文楷 LXGW WenKai</option>
                  <option>Noto Serif SC</option>
                  <option>Ma Shan Zheng</option>
                  <option>Smiley Sans</option>
                </select>
              </label>
              <div class="control-grid">
                <label>字号 <input type="text" value="22" readonly /></label>
                <label>透明 <input type="text" value="92%" readonly /></label>
                <label>行距 <input type="text" value="1.45" readonly /></label>
                <label>角度 <input type="text" value="-2°" readonly /></label>
              </div>
              <div class="color-row" aria-label="文字颜色">
                <span class="ink active"></span>
                <span class="moss"></span>
                <span class="brown"></span>
                <span class="rose"></span>
              </div>
            </section>

            <section class="inspector-card layer-card" aria-labelledby="layers-title">
              <div class="panel-title compact">
                <strong id="layers-title">图层</strong>
                <span>Layers</span>
              </div>
              <ol class="layer-list">
                <li><span>08</span> 选中：<span data-layer-selected-name>{initialMaterialItem.name}</span></li>
                <li><span>07</span> 花枝贴纸</li>
                <li><span>06</span> 引用卡片</li>
                <li><span>05</span> 相册图片</li>
              </ol>
            </section>
          </aside>
        </div>
      </div>
    </section>

    <section class="design-screen source-screen" aria-labelledby="source-title">
      <div class="screen-heading">
        <p class="screen-index">Source Map</p>
        <h2 id="source-title">字体与素材来源要写进 manifest</h2>
        <p>
          设计稿里出现的素材必须有来源和授权记录；Pinterest 和小红书只当灵感，不作为内置素材来源。
        </p>
      </div>
      <div class="source-grid">
        <article>
          <strong>字体</strong>
          <span>LXGW WenKai / Smiley Sans / Ma Shan Zheng / Noto Serif SC</span>
        </article>
        <article>
          <strong>插图素材</strong>
          <span>Illustcenter 图标与 Rawpixel CC0 植物卡，逐项写入 sheet manifest。</span>
        </article>
        <article>
          <strong>纸张和胶带</strong>
          <span>实现阶段从 DigitalScrapbook 等来源逐个核对授权后加入。</span>
        </article>
      </div>
    </section>
  </section>
</BaseLayout>

<script is:inline define:vars={{ materialSheets }}>
  const itemsPerPage = 4;
  const explorer = document.querySelector("[data-sheet-explorer]");

  if (explorer) {
    const featuredMaterial = explorer.querySelector("[data-featured-material]");
    const featuredImage = explorer.querySelector("[data-featured-image]");
    const materialGrid = explorer.querySelector("[data-material-grid]");
    const sheetName = explorer.querySelector("[data-sheet-name]");
    const materialName = explorer.querySelector("[data-material-name]");
    const pageCounter = explorer.querySelector("[data-material-page-counter]");
    const canvasMaterial = document.querySelector("[data-canvas-material]");
    const selectedLayerName = document.querySelector("[data-layer-selected-name]");
    const state = { sheetIndex: 0, pageIndex: 0, selectedItemIndex: 0 };

    const activeSheet = () => materialSheets[state.sheetIndex];
    const activePageItems = () => {
      const start = state.pageIndex * itemsPerPage;
      return activeSheet().items.slice(start, start + itemsPerPage);
    };

    const selectItem = (item, itemIndex) => {
      state.selectedItemIndex = itemIndex;
      featuredImage.src = item.src;
      featuredImage.alt = item.name;
      featuredMaterial.setAttribute("aria-label", `当前选择：${item.name}`);
      materialName.textContent = item.name;
      canvasMaterial.src = item.src;
      canvasMaterial.alt = item.name;
      selectedLayerName.textContent = item.name;
    };

    const render = () => {
      const sheet = activeSheet();
      const pageItems = activePageItems();
      const totalPages = Math.ceil(sheet.items.length / itemsPerPage);

      sheetName.textContent = sheet.name;
      pageCounter.textContent = `${state.pageIndex + 1} / ${totalPages}`;
      explorer.querySelectorAll("[data-material-sheet]").forEach((button) => {
        const isActive = Number(button.dataset.materialSheet) === state.sheetIndex;
        button.classList.toggle("active", isActive);
        button.setAttribute("aria-selected", String(isActive));
      });

      materialGrid.replaceChildren(
        ...pageItems.map((item, index) => {
          const itemIndex = state.pageIndex * itemsPerPage + index;
          const button = document.createElement("button");
          const image = document.createElement("img");
          const isSelected = itemIndex === state.selectedItemIndex;

          button.type = "button";
          button.className = "material-thumbnail";
          button.classList.toggle("active", isSelected);
          button.dataset.materialIndex = String(itemIndex);
          button.setAttribute("aria-label", `选择${item.name}`);
          button.setAttribute("aria-pressed", String(isSelected));
          image.src = item.src;
          image.alt = "";
          image.loading = "lazy";
          button.append(image);
          return button;
        })
      );

      const selectedItem = sheet.items[state.selectedItemIndex] ?? pageItems[0];
      selectItem(selectedItem, state.selectedItemIndex);
    };

    explorer.addEventListener("click", (event) => {
      const target = event.target;
      if (!(target instanceof Element)) return;

      const sheetButton = target.closest("[data-material-sheet]");
      if (sheetButton) {
        state.sheetIndex = Number(sheetButton.getAttribute("data-material-sheet"));
        state.pageIndex = 0;
        state.selectedItemIndex = 0;
        render();
        return;
      }

      const pageButton = target.closest("[data-material-page]");
      if (pageButton) {
        const totalPages = Math.ceil(activeSheet().items.length / itemsPerPage);
        const direction = pageButton.getAttribute("data-material-page") === "next" ? 1 : -1;
        state.pageIndex = (state.pageIndex + direction + totalPages) % totalPages;
        state.selectedItemIndex = state.pageIndex * itemsPerPage;
        render();
        return;
      }

      const materialButton = target.closest("[data-material-index]");
      if (materialButton) {
        const itemIndex = Number(materialButton.getAttribute("data-material-index"));
        selectItem(activeSheet().items[itemIndex], itemIndex);
        materialGrid.querySelectorAll("[data-material-index]").forEach((button) => {
          const isSelected = Number(button.getAttribute("data-material-index")) === itemIndex;
          button.classList.toggle("active", isSelected);
          button.setAttribute("aria-pressed", String(isSelected));
        });
      }
    });
  }
</script>
