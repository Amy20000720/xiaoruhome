---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { readJournalMaterialSheets } from "../../lib/journalMaterialSheets";
import "../../styles/journal-studio.css";

const isLocalStudio = import.meta.env.DEV;
const today = new Date().toISOString().slice(0, 10);
const sheets = isLocalStudio ? await readJournalMaterialSheets() : [];
const studioData = {
  base: import.meta.env.BASE_URL,
  sheets: sheets.map((sheet) => ({
    ...sheet,
    items: sheet.items.map((item) => ({
      ...item,
      src: `/assets/life-journal/sheets/${sheet.id}/${item.file}`,
    })),
  })),
};
const studioDataJson = JSON.stringify(studioData).replace(/</g, "\\u003c");
---

<BaseLayout title="读书手帐 Studio" description="本地竖版 B5 读书手帐编辑器。" wide>
  {
    isLocalStudio ? (
      <section class="journal-studio reading-studio" data-journal-studio>
        <header class="studio-header">
          <div>
            <p class="eyebrow">Reading Journal Studio</p>
            <h1>读书手帐 Studio</h1>
            <p class="studio-intro">一张竖版 B5 空白页。把素材、照片和文字自由叠在一起。</p>
          </div>
          <p class="studio-local-badge">本地编辑</p>
        </header>

        <div class="reading-studio-layout">
          <aside class="studio-panel studio-material-panel" aria-label="素材工具箱">
            <div class="panel-heading">
              <div>
                <p class="panel-kicker">Material sheets</p>
                <h2>素材工具箱</h2>
              </div>
              <span data-sheet-count></span>
            </div>

            <div class="sheet-tabs" data-sheet-tabs aria-label="素材 Sheet"></div>
            <div class="sheet-browser-head">
              <button class="studio-icon-button" type="button" data-action="previous-sheet-page" aria-label="上一组素材" title="上一组素材">←</button>
              <p data-sheet-page-label>素材加载中</p>
              <button class="studio-icon-button" type="button" data-action="next-sheet-page" aria-label="下一组素材" title="下一组素材">→</button>
            </div>
            <div class="material-grid" data-material-grid aria-live="polite"></div>
            <p class="material-source" data-material-source></p>

            <div class="material-tools">
              <button class="studio-button" type="button" data-action="add-text">添加文字</button>
              <label class="studio-upload">
                <span>上传图片</span>
                <input type="file" accept="image/png,image/jpeg,image/webp,image/gif" data-action="upload-image" />
              </label>
            </div>
          </aside>

          <section class="studio-workspace" aria-label="竖版 B5 手帐画布">
            <div class="studio-canvas-toolbar" aria-label="画布操作栏">
              <button class="studio-icon-button active" type="button" data-action="select" title="选择对象">选择</button>
              <button class="studio-icon-button" type="button" data-action="duplicate" title="复制当前对象">复制</button>
              <button class="studio-icon-button" type="button" data-action="bring-forward" title="向前一层">前移</button>
              <button class="studio-icon-button" type="button" data-action="send-backward" title="向后一层">后移</button>
              <button class="studio-icon-button" type="button" data-action="bring-front" title="置于顶层">置顶</button>
              <button class="studio-icon-button" type="button" data-action="send-back" title="置于底层">置底</button>
              <button class="studio-icon-button danger" type="button" data-action="delete" title="删除当前对象">删除</button>
              <button class="studio-icon-button quiet" type="button" data-action="new-page" title="清空画布并新建 B5 页">新建</button>
            </div>

            <div class="b5-canvas-stage">
              <div class="b5-page-marker" aria-hidden="true">B5 / READING JOURNAL</div>
              <div class="studio-canvas-shell">
                <canvas id="journal-canvas" width="420" height="594"></canvas>
              </div>
            </div>

            <footer class="studio-footer-actions">
              <div>
                <button class="studio-button ghost" type="button" data-action="save">保存草稿</button>
                <button class="studio-button primary" type="button" data-action="publish">发布</button>
              </div>
              <p class="studio-status" data-studio-status role="status">草稿只存于当前浏览器。</p>
              <a class="studio-public-link" data-public-link hidden target="_blank" rel="noreferrer">查看公开页面</a>
            </footer>
          </section>

          <aside class="studio-panel studio-inspector-panel" aria-label="文字、对象和发布设置">
            <section class="inspector-section">
              <div class="panel-heading compact-heading">
                <div>
                  <p class="panel-kicker">Typography</p>
                  <h2>文字</h2>
                </div>
              </div>
              <label>
                <span>字体</span>
                <select id="text-font">
                  <option value="serif">Noto Serif SC</option>
                  <option value="sans">Noto Sans SC</option>
                  <option value="wenkai">LXGW WenKai</option>
                  <option value="hand">Ma Shan Zheng</option>
                </select>
              </label>
              <div class="studio-field-grid">
                <label>
                  <span>字号</span>
                  <input id="text-size" type="number" min="10" max="72" value="22" />
                </label>
                <label>
                  <span>颜色</span>
                  <input id="text-color" type="color" value="#3d3a32" />
                </label>
              </div>
              <label>
                <span>对齐</span>
                <select id="text-align">
                  <option value="left">左对齐</option>
                  <option value="center">居中</option>
                  <option value="right">右对齐</option>
                </select>
              </label>
            </section>

            <section class="inspector-section">
              <div class="panel-heading compact-heading">
                <div>
                  <p class="panel-kicker">Object</p>
                  <h2>对象</h2>
                </div>
                <output data-selected-name>未选择</output>
              </div>
              <div class="studio-field-grid">
                <label>
                  <span>X</span>
                  <input id="selected-x" type="number" data-transform-field="x" />
                </label>
                <label>
                  <span>Y</span>
                  <input id="selected-y" type="number" data-transform-field="y" />
                </label>
                <label>
                  <span>宽度</span>
                  <input id="selected-width" type="number" min="8" data-transform-field="width" />
                </label>
                <label>
                  <span>旋转</span>
                  <input id="selected-angle" type="number" min="-180" max="180" data-transform-field="angle" />
                </label>
              </div>
              <label>
                <span>不透明度</span>
                <input id="selected-opacity" type="range" min="0.1" max="1" step="0.05" data-transform-field="opacity" value="1" />
              </label>
            </section>

            <section class="inspector-section">
              <div class="panel-heading compact-heading">
                <div>
                  <p class="panel-kicker">Layers</p>
                  <h2>图层</h2>
                </div>
              </div>
              <div class="layer-list" data-layer-list><p>画布还是空白的。</p></div>
            </section>

            <section class="inspector-section">
              <div class="panel-heading compact-heading">
                <div>
                  <p class="panel-kicker">Publish details</p>
                  <h2>发布信息</h2>
                </div>
              </div>
              <label>
                <span>标题</span>
                <input id="journal-title" type="text" value="新的读书手帐页" />
              </label>
              <div class="studio-field-grid">
                <label>
                  <span>日期</span>
                  <input id="journal-date" type="date" value={today} />
                </label>
                <label>
                  <span>心情</span>
                  <input id="journal-mood" type="text" value="沉浸" />
                </label>
              </div>
              <label>
                <span>摘要</span>
                <textarea id="journal-summary" rows="3">一张新的读书手帐页。</textarea>
              </label>
              <div class="studio-field-grid">
                <label>
                  <span>标签</span>
                  <input id="journal-tags" type="text" value="读书, 手帐" />
                </label>
                <label>
                  <span>地点</span>
                  <input id="journal-location" type="text" value="个人网站" />
                </label>
              </div>
              <label>
                <span>Slug</span>
                <input id="journal-slug" type="text" value="reading-journal-page" autocomplete="off" />
              </label>
              <label>
                <span>正文</span>
                <textarea id="journal-body" rows="5">今天记录一点读书时想到的事情。</textarea>
              </label>
            </section>
          </aside>
        </div>
      </section>
    ) : (
      <section class="studio-local-only">
        <p class="eyebrow">Reading Journal Studio</p>
        <h1>本地编辑器仅在开发环境可用</h1>
        <p>公开站点只展示已经发布的读书手帐页。</p>
      </section>
    )
  }

  {isLocalStudio && <script id="journal-material-sheets" type="application/json" is:inline set:html={studioDataJson}></script>}
  {isLocalStudio && <script>import "../../scripts/journal-studio.ts";</script>}
</BaseLayout>
