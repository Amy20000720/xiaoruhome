---
import { withBase } from "../lib/paths";
import {
  getJournalAsset,
  JOURNAL_PAGE_HEIGHT,
  JOURNAL_PAGE_WIDTH,
} from "../lib/journalAssets";
import type { JournalElement } from "../lib/journalLayout";

interface Props {
  element: JournalElement;
}

const { element } = Astro.props;
const asset = getJournalAsset(element.assetId);
const classNames = [
  "journal-element",
  `journal-element-${element.type}`,
  element.style && `journal-style-${element.style}`,
  asset?.className,
].filter(Boolean);

const fontFamilies = {
  serif: '"Noto Serif SC", "Songti SC", STSong, serif',
  sans: '"Noto Sans SC", "PingFang SC", "Hiragino Sans GB", sans-serif',
  wenkai: '"LXGW WenKai", KaiTi, STKaiti, cursive',
  hand: '"Ma Shan Zheng", KaiTi, STKaiti, cursive',
};
const textStyle = element.textStyle;
const textFont = textStyle?.font && textStyle.font in fontFamilies ? fontFamilies[textStyle.font] : fontFamilies.serif;
const textSize = Math.max(10, Math.min(72, textStyle?.fontSize ?? 22));
const textColor = /^#[0-9a-f]{6}$/i.test(textStyle?.color ?? "") ? textStyle?.color : "#3d3a32";
const textAlign = textStyle?.align === "center" || textStyle?.align === "right" ? textStyle.align : "left";
const textLineHeight = Math.max(0.8, Math.min(2.4, textStyle?.lineHeight ?? 1.35));
const opacity = Math.max(0.1, Math.min(1, element.opacity ?? 1));

const style = [
  `--x: ${(element.x / JOURNAL_PAGE_WIDTH) * 100}%`,
  `--y: ${(element.y / JOURNAL_PAGE_HEIGHT) * 100}%`,
  `--w: ${(element.width / JOURNAL_PAGE_WIDTH) * 100}%`,
  `--h: ${(element.height / JOURNAL_PAGE_HEIGHT) * 100}%`,
  `--r: ${element.rotation ?? 0}deg`,
  `--z: ${element.zIndex ?? 2}`,
  `--journal-opacity: ${opacity}`,
  `--journal-text-font: ${textFont}`,
  `--journal-text-size: ${textSize}px`,
  `--journal-text-color: ${textColor}`,
  `--journal-text-align: ${textAlign}`,
  `--journal-text-line-height: ${textLineHeight}`,
].join("; ");

const imageSrc = element.src ? withBase(element.src) : "";
const label = element.text ?? asset?.defaultText ?? asset?.name ?? "";
---

{
  element.src ? (
    <figure class:list={classNames} style={style}>
      <img src={imageSrc} alt={element.alt ?? ""} loading="lazy" />
    </figure>
  ) : element.type === "tape" || element.type === "frame" ? (
    <div class:list={classNames} style={style} aria-hidden="true"></div>
  ) : (
    <div class:list={classNames} style={style}>
      {label && <span>{label}</span>}
    </div>
  )
}
